                question: "Qui a participé à la découverte de l'isotopie et reçu le prix Nobel de chimie en 1922 ?",
                options: ["Francis William Aston", "Albert Einstein", "M. Jérôme", "Max Welfar"],
                correct: 0,
                hint: "Son nom a été donné à la courbe d'énergie nucléaire par nucléon.",
                rationale: "Francis William Aston a recensé les isotopes stables et a été récompensé en 1922."
            },
            {
                lesson: "3.1 Principe de la fission",
                difficulty: "Facile",
                question: "Qu'est-ce qu'une fission nucléaire ?",
                options: ["Un noyau lourd qui éclate en deux noyaux plus légers sous l'impact d'un neutron", "La réunion de deux noyaux légers", "L'émission spontanée d'un rayonnement gamma sans changement de masse", "La perte totale des électrons d'un atome"],
                correct: 0,
                hint: "C'est une réaction provoquée par un projectile neutre.",
                rationale: "La fission implique l'éclatement d'un noyau lourd initié par l'impact d'un neutron."
            },
            {
                lesson: "3.1 Principe de la fission",
                difficulty: "Intermédiaire",
                question: "Quel isotope lourd est couramment cité pour illustrer la fission provoquée ?",
                options: ["L'Uranium 235", "Le Fer 56", "Le Deutérium", "Le Lithium 6"],
                correct: 0,
                hint: "Son nombre de nucléons est de 235.",
                rationale: "Le cours étudie la fission de l'uranium 235 sous l'impact d'un neutron."
            },
            {
                lesson: "3.1 Principe de la fission",
                difficulty: "Analyse",
                question: "Comment appelle-t-on le phénomène où les neutrons produits par une fission vont à leur tour casser d'autres noyaux ?",
                options: ["Une réaction en chaîne", "Une fusion en continu", "Une équivalence absolue", "Une combustion fossile"],
                correct: 0,
                hint: "Ce phénomène nécessite un contrôle rigoureux dans les réacteurs.",
                rationale: "La libération de neutrons supplémentaires engendre une réaction en chaîne."
            },
            {
                lesson: "4. Principe de la fusion",
                difficulty: "Facile",
                question: "Qu'est-ce que la fusion nucléaire ?",
                options: ["Deux noyaux légers qui s'unissent pour former un noyau plus lourd", "L'éclatement d'un noyau d'uranium", "La combustion d'hydrogène avec de l'oxygène", "Le ralentissement des neutrons"],
                correct: 0,
                hint: "C'est le mécanisme qui alimente notre Soleil.",
                rationale: "La fusion associe des noyaux légers pour donner un noyau plus lourd et plus stable."
            },
            {
                lesson: "4. Principe de la fusion",
                difficulty: "Intermédiaire",
                question: "Quels isotopes de l'hydrogène fusionnent pour former de l'hélium dans les recherches actuelles ?",
                options: ["Le deutérium et le tritium", "L'uranium et le strontium", "Le fer et le nickel", "Le carbone et l'azote"],
                correct: 0,
                hint: "Ils ont pour symboles respectifs 2_1 H et 3_1 H.",
                rationale: "La réaction s'effectue entre le deutérium et le tritium."
            },
            {
                lesson: "4. Principe de la fusion",
                difficulty: "Analyse",
                question: "Quelle arme historique, testée en 1952, utilise le principe de la fusion non contrôlée ?",
                options: ["La bombe H", "La bombe A", "Le réacteur ITER", "Le missile Cadarache"],
                correct: 0,
                hint: "Elle s'avère mille fois plus puissante que la bombe à fission initiale.",
                rationale: "La bombe H (bombe à hydrogène) libère l'énergie de fusion de manière explosive non contrôlée."
            }
        ];

        // --- ÉTAT DU JEU ---
        let currentQuestionIndex = 0;
        let score = 0;
        let isAudioContextInitialized = false;
        let audioCtx = null;
        let musicInterval = null;
        let playMusic = false;
        let playEffects = true;

        // Compte à rebours : 20 minutes = 1200 secondes
        let timeLeft = 1200; 
        let countdownTimer = null;

        // --- GESTION DU TEMPS ---
        function startTimer() {
            if (countdownTimer) clearInterval(countdownTimer);
            countdownTimer = setInterval(() => {
                timeLeft--;
                updateTimerDisplay();
                
                if (timeLeft <= 0) {
                    clearInterval(countdownTimer);
                    timeOver();
                }
            }, 1000);
        }

        function updateTimerDisplay() {
            let minutes = Math.floor(timeLeft / 60);
            let seconds = timeLeft % 60;
            document.getElementById('timerBadge').innerText = `⏱️ ${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
        }

        function timeOver() {
            // Désactiver le jeu pour cause de temps écoulé
            document.getElementById('endTitle').innerText = "⏱️ Temps écoulé ! ⏱️";
            document.getElementById('endSubtitle').innerText = "Les 20 minutes sont terminées. Voyons votre résultat final :";
            showScoreScreen();
        }

        // --- INITIALISATION DU SYSTÈME AUDIO ---
        function initAudio() {
            if (isAudioContextInitialized) return;
            try {
                audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                isAudioContextInitialized = true;
            } catch(e) {
                console.error("L'API Web Audio n'est pas supportée.");
            }
        }

        function playTone(freq, type, duration) {
            if (!playEffects || !isAudioContextInitialized) return;
            try {
                let osc = audioCtx.createOscillator();
                let gain = audioCtx.createGain();
                osc.type = type;
                osc.frequency.value = freq;
                gain.gain.setValueAtTime(0.1, audioCtx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.00001, audioCtx.currentTime + duration);
                osc.connect(gain);
                gain.connect(audioCtx.destination);
                osc.start();
                osc.stop(audioCtx.currentTime + duration);
            } catch(e) {}
        }

        function startMusicLoop() {
            if (musicInterval) clearInterval(musicInterval);
            let notes = [261.63, 293.66, 329.63, 349.23, 392.00, 440.00];
            let i = 0;
            musicInterval = setInterval(() => {
                if (playMusic && isAudioContextInitialized) {
                    playTone(notes[i % notes.length], 'sine', 0.6);
                    i++;
                }
            }, 800);
        }

        function toggleMusic() {
            initAudio();
            playMusic = !playMusic;
            document.getElementById('bgMusicBtn').innerText = playMusic ? "🎵 Musique : ON" : "🎵 Musique : OFF";
            if (playMusic && isAudioContextInitialized) {
                if(audioCtx.state === 'suspended') audioCtx.resume();
                startMusicLoop();
            }
        }

        function toggleSounds() {
            initAudio();
            playEffects = !playEffects;
            document.getElementById('soundEffectsBtn').innerText = playEffects ? "🔊 Sons : ON" : "🔊 Sons : OFF";
        }

        // --- LOGIQUE D'AFFICHAGE ---
        function loadQuestion() {
            initAudio();
            if (audioCtx && audioCtx.state === 'suspended') audioCtx.resume();

            document.getElementById('hintBox').style.display = "none";
            document.getElementById('feedbackMessage').style.display = "none";

            if (currentQuestionIndex >= questionsDatabase.length) {
                clearInterval(countdownTimer);
                showScoreScreen();
                return;
            }

            document.getElementById('questionNumDisplay').innerText = `Question ${currentQuestionIndex + 1} sur ${questionsDatabase.length}`;
            document.getElementById('scoreDisplay').innerText = `Score : ${score.toString().padStart(2, '0')}/${questionsDatabase.length}`;
            let progressPercent = ((currentQuestionIndex) / questionsDatabase.length) * 100;
            document.getElementById('progressBarFill').style.width = `${progressPercent}%`;

            let q = questionsDatabase[currentQuestionIndex];
            document.getElementById('lessonTag').innerText = q.lesson;
            document.getElementById('questionText').innerText = q.question;
            
            let diff = document.getElementById('diffTag');
            diff.innerText = q.difficulty;
            diff.className = "difficulty-tag";
            if (q.difficulty === "Facile") diff.classList.add('diff-easy');
            else if (q.difficulty === "Intermédiaire") diff.classList.add('diff-medium');
            else diff.classList.add('diff-hard');

            let grid = document.getElementById('optionsGrid');
            grid.innerHTML = "";
            q.options.forEach((opt, idx) => {
                let btn = document.createElement('button');
                btn.className = "option-btn";
                btn.innerText = opt;
                btn.onclick = () => checkAnswer(idx, btn);
                grid.appendChild(btn);
            });
        }

        function checkAnswer(selectedIndex, clickedBtn) {
            let q = questionsDatabase[currentQuestionIndex];
            let msg = document.getElementById('feedbackMessage');
            let buttons = document.querySelectorAll('.option-btn');

            if (selectedIndex === q.correct) {
                clickedBtn.classList.add('correct');
                score++;
                document.getElementById('scoreDisplay').innerText = `Score : ${score.toString().padStart(2, '0')}/${questionsDatabase.length}`;
                
                playTone(523.25, 'triangle', 0.15);
                setTimeout(() => playTone(659.25, 'triangle', 0.15), 100);
                setTimeout(() => playTone(783.99, 'triangle', 0.3), 200);

                createParticles(clickedBtn);

                msg.className = "feedback-message feedback-success";
                msg.innerText = `🌟 Excellent ! ${q.rationale}`;
                msg.style.display = "block";

                buttons.forEach(b => b.disabled = true);

                setTimeout(() => {
                    currentQuestionIndex++;
                    loadQuestion();
                }, 3500);

            } else {
                clickedBtn.classList.add('incorrect');
                clickedBtn.disabled = true;
                playTone(180, 'sawtooth', 0.4);

                msg.className = "feedback-message feedback-error";
                msg.innerText = "❌ Ce n'est pas tout à fait ça, essaie encore ! Relis bien la question.";
                msg.style.display = "block";
            }
        }

        function showHint() {
            let q = questionsDatabase[currentQuestionIndex];
            let box = document.getElementById('hintBox');
            box.innerText = q.hint;
            box.style.display = "block";
            playTone(440, 'sine', 0.1);
        }

        function createParticles(element) {
            const rect = element.getBoundingClientRect();
            const container = document.getElementById('quizContainer');
            
            for (let i = 0; i < 20; i++) {
                let p = document.createElement('div');
                p.className = 'particle';
                const colors = ['#38bdf8', '#34d399', '#fbbf24', '#f472b6', '#60a5fa'];
                p.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
                p.style.left = (rect.left + rect.width / 2 - window.scrollX) + 'px';
                p.style.top = (rect.top + rect.height / 2 - window.scrollY) + 'px';
                
                const angle = Math.random() * Math.PI * 2;
                const distance = 50 + Math.random() * 100;
                p.style.setProperty('--x', `${Math.cos(angle) * distance}px`);
                p.style.setProperty('--y', `${Math.sin(angle) * distance}px`);
                
                container.appendChild(p);
                setTimeout(() => p.remove(), 1000);
            }
        }

        function showScoreScreen() {
            document.getElementById('quizCard').style.display = "none";
            document.getElementById('progressSection').style.display = "none";
            
            let screen = document.getElementById('scoreScreen');
            screen.style.display = "block";
            
            document.getElementById('finalScoreBadge').innerText = `${score} / ${questionsDatabase.length}`;
            
            let evaluation = "";
            if (score === questionsDatabase.length) evaluation = "🏆 Parfait ! Vous maîtrisez parfaitement l'équivalence masse-énergie et les processus nucléaires !";
            else if (score >= 20) evaluation = "🥈 Très bien ! Les notions fondamentales du cours sont bien acquises !";
            else if (score >= 15) evaluation = "👍 Score correct. Une relecture attentive du document d'Einstein et d'Aston vous permettra de vous perfectionner.";
            else evaluation = "📚 Courage ! Repassez le test et étudiez attentivement les définitions du défaut de masse et des liaisons.";
            
            document.getElementById('finalEvaluationText').innerText = evaluation;
        }

        function restartQuiz() {
            currentQuestionIndex = 0;
            score = 0;
            timeLeft = 1200; // Reset des 20 minutes
            document.getElementById('endTitle').innerText = "🎉 Travail terminé ! 🎉";
            document.getElementById('endSubtitle').innerText = "Félicitations pour avoir parcouru l'ensemble des notions clés du manuel.";
            document.getElementById('quizCard').style.display = "block";
            document.getElementById('progressSection').style.display = "block";
            document.getElementById('scoreScreen').style.display = "none";
            updateTimerDisplay();
            startTimer();
            loadQuestion();
        }

        window.onload = () => {
            startTimer();
            loadQuestion();
        };
    </script>
</body>
